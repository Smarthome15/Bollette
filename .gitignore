# Python cache and compiled files
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc

# Virtual environment folders
venv/
.venv/
.env/
.env
ENV/
env/

# Segreti locali (chiavi API, ecc.) - NON versionare, in QUALSIASI cartella
secrets_local.py
**/secrets_local.py

# Dati locali e runtime: l'intera cartella database NON va versionata
# (include i JSON dati, i file delle letture manuali *_man_* e i PDF salvati in database/pdfs)
database/

# Backup locali del codice app del NAS (creati prima di ogni pubblicazione)
backup_nas/

# Pacchetto backend per un altro PC: generato da prepara_install.bat, non versionato
# (contiene anche secrets_local.py). Lo script SÌ è versionato.
install/

# Distribution / packaging
build/
dist/
*.egg-info/
pip-wheel-metadata/

# IDE/editor settings
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# OS generated files
.DS_Store
Thumbs.db

# Logs
*.log

# Pytest / type checker cache
.pytest_cache/
.mypy_cache/
.dmypy.json
